# ── Brevo (Sendinblue) ──────────────────────────────────────────────────────
# Get your free API key at https://app.brevo.com → Settings → API Keys
BREVO_API_KEY=your_brevo_api_key_here

# The "From" address you verified in Brevo
BREVO_SENDER_EMAIL=alerts@yourdomain.com
BREVO_SENDER_NAME=AuroraWatch

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001

# URL of your frontend (used for CORS and email unsubscribe links)
FRONTEND_URL=http://localhost:5500

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite file path (relative to project root)
DB_PATH=./data/aurora.db

# ── Cron schedule ────────────────────────────────────────────────────────────
# Default: check every hour at :00  (cron syntax)
ALERT_CRON_SCHEDULE=0 * * * *

# Minimum hours between alerts for the same subscriber (prevents spam)
MIN_ALERT_INTERVAL_HOURS=4
